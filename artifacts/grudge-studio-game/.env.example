# ── Grudge Studio Game — Environment Variables ────────────────
# Copy to .env.local for local development.
# On Vercel, set these in Project Settings > Environment Variables.

# ── Backend API URLs ──────────────────────────────────────────
VITE_AUTH_URL=https://id.grudge-studio.com
VITE_API_URL=https://api.grudge-studio.com
VITE_ACCOUNT_URL=https://account.grudge-studio.com

# ── Asset CDN (R2 / Cloudflare) ──────────────────────────────
# Set VITE_USE_CDN=true ONLY after CORS is configured on the CDN.
# When false (default), models load from local public/ folder.
VITE_USE_CDN=false
VITE_ASSET_CDN_URL=https://assets.grudge-studio.com

# ── Object Storage (game data JSON — items, weapons, armor) ──
VITE_OBJECT_STORE_URL=https://grudge-objectstore.pages.dev/api/v1

# ── WebSocket (live presence, PvP) ────────────────────────────
VITE_WS_URL=wss://ws.grudge-studio.com
