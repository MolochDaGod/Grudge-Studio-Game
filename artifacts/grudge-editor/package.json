{
  "name": "@workspace/grudge-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Grudge Studio editor service — extensible Node backend for asset conversion (FBX→GLB, zip), optimization (glTF-Transform / Draco / Meshopt / KTX2), and integrations (object storage, puter clouds, game registry).",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --experimental-strip-types src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@hono/node-server": "^1.12.0",
    "draco3dgltf": "^1.5.7",
    "fflate": "^0.8.2",
    "hono": "^4.6.0",
    "meshoptimizer": "^0.22.0",
    "three": "^0.183.2",
    "three-stdlib": "^2.36.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "~5.9.2"
  }
}
